// Firestore Security Rules for PrepKLE
// Copy this to: Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== NOTES COLLECTION =====
    match /notes/{noteId} {
      // Anyone can read approved notes
      allow read: if resource.data.status == 'approved' || request.auth != null;
      
      // Anyone can view pending notes (for admin)
      allow read: if resource.data.status == 'pending';
      
      // Anyone can create new notes (open submission)
      allow create: if request.resource.data.title != null
                       && request.resource.data.branch != null
                       && request.resource.data.semester != null
                       && request.resource.data.subject != null
                       && request.resource.data.pdfUrl != null
                       && request.resource.data.status == 'pending';
      
      // Only authenticated users (future admins) can update
      allow update: if request.auth != null;
      
      // Only authenticated users can delete
      allow delete: if request.auth != null;
    }
    
    // ===== COMMENTS COLLECTION =====
    match /comments/{commentId} {
      // Anyone can read all comments
      allow read: if true;
      
      // Anyone can create comments
      allow create: if request.resource.data.noteId != null
                       && request.resource.data.name != null
                       && request.resource.data.comment != null
                       && request.resource.data.createdAt != null;
      
      // Users can only delete their own comments (requires auth)
      allow delete: if request.auth != null;
      
      // No updates allowed
      allow update: if false;
    }
    
    // ===== ADMINS COLLECTION =====
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // ===== CATCH-ALL =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
